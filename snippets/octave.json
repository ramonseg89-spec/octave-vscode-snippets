{
  "Octave For Loop": {
    "prefix": "for",
    "body": [
      "for ${1:i} = ${2:1}:${3:n}",
      "\t${4:% cuerpo del bucle}",
      "endfor"
    ],
    "description": "Bucle for basico (start:end)"
  },
  "Octave For Loop with Step": {
    "prefix": "fors",
    "body": [
      "for ${1:i} = ${2:start}:${3:step}:${4:end}",
      "\t${5:% cuerpo del bucle}",
      "endfor"
    ],
    "description": "Bucle for con paso (start:step:end)"
  },
  "Octave While Loop": {
    "prefix": "while",
    "body": [
      "while (${1:condicion})",
      "\t${2:% cuerpo del bucle}",
      "endwhile"
    ],
    "description": "Bucle while"
  },
  "Octave If": {
    "prefix": "if",
    "body": [
      "if (${1:condicion})",
      "\t${2:% rama verdadera}",
      "endif"
    ],
    "description": "Estructura if simple"
  },
  "Octave If-Else": {
    "prefix": "ife",
    "body": [
      "if (${1:condicion})",
      "\t${2:% rama verdadera}",
      "else",
      "\t${3:% rama falsa}",
      "endif"
    ],
    "description": "Estructura if-else"
  },
  "Octave If-Elseif-Else": {
    "prefix": "ifee",
    "body": [
      "if (${1:condicion1})",
      "\t${2:% primera rama}",
      "elseif (${3:condicion2})",
      "\t${4:% segunda rama}",
      "else",
      "\t${5:% rama por defecto}",
      "endif"
    ],
    "description": "Estructura if-elseif-else"
  },
  "Octave Switch": {
    "prefix": "switch",
    "body": [
      "switch (${1:variable})",
      "\tcase ${2:valor1}",
      "\t\t${3:% accion caso 1}",
      "\tcase ${4:valor2}",
      "\t\t${5:% accion caso 2}",
      "\totherwise",
      "\t\t${6:% accion por defecto}",
      "endswitch"
    ],
    "description": "Estructura switch-case-otherwise"
  },
  "Octave Function (single return)": {
    "prefix": "fun",
    "body": [
      "function ${1:retval} = ${2:nombre} (${3:args})",
      "\t${4:% cuerpo de la funcion}",
      "\t${1:retval} = ${5:0};",
      "endfunction"
    ],
    "description": "Funcion con un valor de retorno"
  },
  "Octave Function (multiple return)": {
    "prefix": "funm",
    "body": [
      "function [${1:out1}, ${2:out2}] = ${3:nombre} (${4:args})",
      "\t${5:% cuerpo de la funcion}",
      "\t${1:out1} = ${6:0};",
      "\t${2:out2} = ${7:0};",
      "endfunction"
    ],
    "description": "Funcion con multiples valores de retorno"
  },
  "Octave Function (void)": {
    "prefix": "funv",
    "body": [
      "function ${1:nombre} (${2:args})",
      "\t${3:% cuerpo de la funcion}",
      "endfunction"
    ],
    "description": "Funcion sin valor de retorno (void)"
  },
  "Octave Try-Catch": {
    "prefix": "try",
    "body": [
      "try",
      "\t${1:% codigo que puede fallar}",
      "catch ${2:err}",
      "\t${3:printf('Error: %s\\n', ${2:err}.message);}",
      "end_try_catch"
    ],
    "description": "Manejo de excepciones try-catch (end_try_catch en Octave)"
  },
  "Octave Row Vector": {
    "prefix": "vec",
    "body": [
      "${1:v} = [${2:1, 2, 3, 4, 5}];"
    ],
    "description": "Vector fila"
  },
  "Octave Column Vector": {
    "prefix": "vecc",
    "body": [
      "${1:v} = [${2:1; 2; 3; 4; 5}];"
    ],
    "description": "Vector columna (separar con punto y coma)"
  },
  "Octave Linspace Vector": {
    "prefix": "lsp",
    "body": [
      "${1:v} = linspace(${2:inicio}, ${3:fin}, ${4:n_puntos});"
    ],
    "description": "Vector con espaciado lineal uniforme"
  },
  "Octave Matrix": {
    "prefix": "mat",
    "body": [
      "${1:M} = [${2:1, 2, 3}; ${3:4, 5, 6}; ${4:7, 8, 9}];"
    ],
    "description": "Matriz (filas separadas con ';')"
  },
  "Octave Zeros Matrix": {
    "prefix": "matz",
    "body": [
      "${1:M} = zeros(${2:filas}, ${3:columnas});"
    ],
    "description": "Matriz de ceros"
  },
  "Octave Ones Matrix": {
    "prefix": "mato",
    "body": [
      "${1:M} = ones(${2:filas}, ${3:columnas});"
    ],
    "description": "Matriz de unos"
  },
  "Octave Identity Matrix": {
    "prefix": "mati",
    "body": [
      "${1:M} = eye(${2:n});"
    ],
    "description": "Matriz identidad n x n"
  },
  "Octave Plot Basic": {
    "prefix": "plot",
    "body": [
      "figure;",
      "plot(${1:x}, ${2:y});",
      "xlabel('${3:Eje X}');",
      "ylabel('${4:Eje Y}');",
      "title('${5:Titulo del grafico}');",
      "grid on;"
    ],
    "description": "Grafico basico con etiquetas, titulo y cuadricula"
  },
  "Octave Plot Styled": {
    "prefix": "plots",
    "body": [
      "figure;",
      "plot(${1:x}, ${2:y}, '${3:b-}', 'LineWidth', ${4:2});",
      "xlabel('${5:Eje X}');",
      "ylabel('${6:Eje Y}');",
      "title('${7:Titulo del grafico}');",
      "legend('${8:Serie 1}');",
      "grid on;"
    ],
    "description": "Grafico con estilo de linea y leyenda"
  },
  "Octave Subplot": {
    "prefix": "subplot",
    "body": [
      "figure;",
      "subplot(${1:filas}, ${2:columnas}, ${3:posicion});",
      "plot(${4:x}, ${5:y});",
      "xlabel('${6:Eje X}');",
      "ylabel('${7:Eje Y}');",
      "title('${8:Subtitulo}');",
      "grid on;"
    ],
    "description": "Subgrafico dentro de una figura"
  },
  "Octave Comment Block": {
    "prefix": "cb",
    "body": [
      "%% --- ${1:Titulo de la seccion} ---",
      "${2}"
    ],
    "description": "Separador de seccion en script"
  },
  "Octave Script Header": {
    "prefix": "header",
    "body": [
      "clc;",
      "clear;",
      "close all;",
      "",
      "${1}"
    ],
    "description": "Inicializacion limpia de script"
  },
  "Octave Printf": {
    "prefix": "pf",
    "body": [
      "printf('${1:%s}\\n', ${2:variable});"
    ],
    "description": "printf con salto de linea"
  },
  "Octave Disp": {
    "prefix": "disp",
    "body": [
      "disp(${1:variable});"
    ],
    "description": "Mostrar valor de variable"
  },
  "Octave Do-Until Loop": {
    "prefix": "do",
    "body": [
      "do",
      "\t${1:% cuerpo del bucle}",
      "until (${2:condicion});"
    ],
    "description": "Bucle do-until (ejecuta al menos una vez)"
  },
  "Octave Main Script": {
    "prefix": "main",
    "body": [
      "clc;",
      "clear;",
      "close all;",
      "",
      "%% --- Parametros ---",
      "${1:% tus variables aqui}",
      "",
      "%% --- Procesamiento ---",
      "${2}",
      "",
      "%% --- Resultados ---",
      "${3:% muestra resultados}"
    ],
    "description": "Estructura limpia de script principal"
  },
  "Octave Nested For": {
    "prefix": "forn",
    "body": [
      "for ${1:i} = ${2:1}:${3:m}",
      "\tfor ${4:j} = ${5:1}:${6:n}",
      "\t\t${7:% cuerpo del bucle interno}",
      "\tendfor",
      "endfor"
    ],
    "description": "Bucles for anidados (filas x columnas)"
  },
  "Octave Inline If (ternario)": {
    "prefix": "ifi",
    "body": [
      "${1:resultado} = ${2:val_verdadero} * (${3:condicion}) + ${4:val_falso} * (!(${3:condicion}));"
    ],
    "description": "Operador ternario inline — Octave no tiene ?: nativo, se simula con aritmetica logica"
  },
  "Octave Printf Multiple": {
    "prefix": "pfm",
    "body": [
      "printf('${1:etiqueta1}: %${2:d}  ${3:etiqueta2}: %${4:f}  ${5:etiqueta3}: %${6:s}\\n', ${7:var1}, ${8:var2}, ${9:var3});"
    ],
    "description": "printf con multiples variables en una sola linea"
  },
  "Octave Figure Custom": {
    "prefix": "fig",
    "body": [
      "figure('Name', '${1:Nombre de la figura}', 'NumberTitle', 'off');",
      "plot(${2:x}, ${3:y}, '${4:b-}', 'LineWidth', ${5:2});",
      "xlabel('${6:Eje X}', 'FontSize', ${7:12});",
      "ylabel('${8:Eje Y}', 'FontSize', ${7:12});",
      "title('${9:Titulo}', 'FontSize', ${10:14});",
      "legend('${11:Serie 1}', 'Location', 'best');",
      "grid on;",
      "axis tight;"
    ],
    "description": "Figura personalizada con nombre, fuentes y eje ajustado"
  },
  "Octave Doc Header": {
    "prefix": "doc",
    "body": [
      "%% Archivo : ${1:nombre}.m",
      "%% Autor   : ${2:Nombre Apellido}",
      "%% Fecha   : ${3:dd/mm/yyyy}",
      "%% Desc.   : ${4:Descripcion del script}"
    ],
    "description": "Bloque de documentacion opcional (autor, fecha, descripcion)"
  },
  "Octave Color Red": {
    "prefix": "red",
    "body": [
      "'r'"
    ],
    "description": "Color rojo para graficos"
  },
  "Octave Color Green": {
    "prefix": "green",
    "body": [
      "'g'"
    ],
    "description": "Color verde para graficos"
  },
  "Octave Color Blue": {
    "prefix": "blue",
    "body": [
      "'b'"
    ],
    "description": "Color azul para graficos"
  },
  "Octave Color Cyan": {
    "prefix": "cyan",
    "body": [
      "'c'"
    ],
    "description": "Color cian para graficos"
  },
  "Octave Color Magenta": {
    "prefix": "magenta",
    "body": [
      "'m'"
    ],
    "description": "Color magenta para graficos"
  },
  "Octave Color Yellow": {
    "prefix": "yellow",
    "body": [
      "'y'"
    ],
    "description": "Color amarillo para graficos"
  },
  "Octave Color Black": {
    "prefix": "black",
    "body": [
      "'k'"
    ],
    "description": "Color negro para graficos"
  },
  "Octave Color White": {
    "prefix": "white",
    "body": [
      "'w'"
    ],
    "description": "Color blanco para graficos"
  },
  "Octave Color RGB Custom": {
    "prefix": "rgb",
    "body": [
      "[${1:0.5}, ${2:0.2}, ${3:0.8}]"
    ],
    "description": "Color RGB personalizado — valores entre 0 y 1"
  },
  "Octave Scatter Plot": {
    "prefix": "scatter",
    "body": [
      "figure;",
      "scatter(${1:x}, ${2:y}, ${3:40}, ${4:'b'}, 'filled');",
      "xlabel('${5:Eje X}');",
      "ylabel('${6:Eje Y}');",
      "title('${7:Diagrama de dispersion}');",
      "grid on;",
      "$0"
    ],
    "description": "Diagrama de dispersion con puntos rellenos"
  },
  "Octave Bar Chart": {
    "prefix": "bar",
    "body": [
      "figure;",
      "bar(${1:x}, ${2:y});",
      "xlabel('${3:Eje X}');",
      "ylabel('${4:Eje Y}');",
      "title('${5:Grafico de barras}');",
      "grid on;",
      "$0"
    ],
    "description": "Grafico de barras verticales"
  },
  "Octave Bar Horizontal": {
    "prefix": "barh",
    "body": [
      "figure;",
      "barh(${1:y}, ${2:x});",
      "xlabel('${3:Valores}');",
      "ylabel('${4:Categorias}');",
      "title('${5:Barras horizontales}');",
      "grid on;",
      "$0"
    ],
    "description": "Grafico de barras horizontales"
  },
  "Octave Histogram": {
    "prefix": "hist",
    "body": [
      "figure;",
      "hist(${1:datos}, ${2:20});",
      "xlabel('${3:Valores}');",
      "ylabel('${4:Frecuencia}');",
      "title('${5:Histograma}');",
      "grid on;",
      "$0"
    ],
    "description": "Histograma con n bins (hist es nativo en Octave 8.4)"
  },
  "Octave Stairs Plot": {
    "prefix": "stairs",
    "body": [
      "figure;",
      "stairs(${1:x}, ${2:y});",
      "xlabel('${3:Eje X}');",
      "ylabel('${4:Eje Y}');",
      "title('${5:Grafico escalonado}');",
      "grid on;",
      "$0"
    ],
    "description": "Grafico escalonado — util para senales discretas"
  },
  "Octave Stem Plot": {
    "prefix": "stem",
    "body": [
      "figure;",
      "stem(${1:x}, ${2:y});",
      "xlabel('${3:Eje X}');",
      "ylabel('${4:Eje Y}');",
      "title('${5:Grafico de tallos}');",
      "grid on;",
      "$0"
    ],
    "description": "Grafico de tallos — senales discretas en el tiempo"
  },
  "Octave Area Plot": {
    "prefix": "area",
    "body": [
      "figure;",
      "area(${1:x}, ${2:y});",
      "xlabel('${3:Eje X}');",
      "ylabel('${4:Eje Y}');",
      "title('${5:Grafico de area}');",
      "grid on;",
      "$0"
    ],
    "description": "Grafico de area rellena bajo la curva"
  },
  "Octave Pie Chart": {
    "prefix": "pie",
    "body": [
      "figure;",
      "pie(${1:valores}, {${2:'A', 'B', 'C'}});",
      "title('${3:Grafico de pastel}');",
      "$0"
    ],
    "description": "Grafico de pastel con etiquetas en cell array"
  },
  "Octave Boxplot": {
    "prefix": "boxplot",
    "body": [
      "% Requiere: pkg load statistics",
      "figure;",
      "boxplot(${1:datos});",
      "title('${2:Diagrama de caja}');",
      "ylabel('${3:Valores}');",
      "grid on;",
      "$0"
    ],
    "description": "Diagrama de caja — requiere pkg statistics (Octave Forge)"
  },
  "Octave Errorbar Plot": {
    "prefix": "errorbar",
    "body": [
      "figure;",
      "errorbar(${1:x}, ${2:y}, ${3:err});",
      "xlabel('${4:Eje X}');",
      "ylabel('${5:Eje Y}');",
      "title('${6:Grafico con barras de error}');",
      "grid on;",
      "$0"
    ],
    "description": "Grafico de linea con barras de error simetrico"
  },
  "Octave Fill Polygon": {
    "prefix": "fill",
    "body": [
      "figure;",
      "fill(${1:x}, ${2:y}, '${3:b}');",
      "xlabel('${4:Eje X}');",
      "ylabel('${5:Eje Y}');",
      "title('${6:Poligono relleno}');",
      "grid on;",
      "$0"
    ],
    "description": "Relleno de poligono definido por vectores x, y"
  },
  "Octave LogLog Plot": {
    "prefix": "loglog",
    "body": [
      "figure;",
      "loglog(${1:x}, ${2:y}, '${3:b-}');",
      "xlabel('${4:Eje X (log)}');",
      "ylabel('${5:Eje Y (log)}');",
      "title('${6:Escala log-log}');",
      "grid on;",
      "$0"
    ],
    "description": "Grafico con ambos ejes en escala logaritmica"
  },
  "Octave Semilogx Plot": {
    "prefix": "semilogx",
    "body": [
      "figure;",
      "semilogx(${1:x}, ${2:y}, '${3:b-}');",
      "xlabel('${4:Eje X (log)}');",
      "ylabel('${5:Eje Y}');",
      "title('${6:Semi-log X}');",
      "grid on;",
      "$0"
    ],
    "description": "Grafico con eje X en escala logaritmica"
  },
  "Octave Semilogy Plot": {
    "prefix": "semilogy",
    "body": [
      "figure;",
      "semilogy(${1:x}, ${2:y}, '${3:b-}');",
      "xlabel('${4:Eje X}');",
      "ylabel('${5:Eje Y (log)}');",
      "title('${6:Semi-log Y}');",
      "grid on;",
      "$0"
    ],
    "description": "Grafico con eje Y en escala logaritmica"
  },
  "Octave Contour Plot": {
    "prefix": "contour",
    "body": [
      "[${1:X}, ${2:Y}] = meshgrid(${3:linspace(-2,2,50)}, ${4:linspace(-2,2,50)});",
      "${5:Z} = ${6:X.^2 + Y.^2};",
      "figure;",
      "contour(${1:X}, ${2:Y}, ${5:Z}, ${7:20});",
      "colorbar;",
      "xlabel('${8:X}');",
      "ylabel('${9:Y}');",
      "title('${10:Grafico de contorno}');",
      "$0"
    ],
    "description": "Grafico de contorno 2D con colorbar"
  },
  "Octave Surf 3D": {
    "prefix": "surf",
    "body": [
      "[${1:X}, ${2:Y}] = meshgrid(${3:linspace(-2,2,40)}, ${4:linspace(-2,2,40)});",
      "${5:Z} = ${6:sin(X) .* cos(Y)};",
      "figure;",
      "surf(${1:X}, ${2:Y}, ${5:Z});",
      "shading interp;",
      "colorbar;",
      "xlabel('${7:X}');",
      "ylabel('${8:Y}');",
      "zlabel('${9:Z}');",
      "title('${10:Superficie 3D}');",
      "$0"
    ],
    "description": "Superficie 3D con shading interpolado y colorbar"
  },
  "Octave Mesh 3D": {
    "prefix": "mesh",
    "body": [
      "[${1:X}, ${2:Y}] = meshgrid(${3:linspace(-2,2,40)}, ${4:linspace(-2,2,40)});",
      "${5:Z} = ${6:X.^2 + Y.^2};",
      "figure;",
      "mesh(${1:X}, ${2:Y}, ${5:Z});",
      "xlabel('${7:X}');",
      "ylabel('${8:Y}');",
      "zlabel('${9:Z}');",
      "title('${10:Malla 3D}');",
      "$0"
    ],
    "description": "Malla 3D wireframe (mesh)"
  },
  "Octave Plot3 Line": {
    "prefix": "plot3",
    "body": [
      "figure;",
      "plot3(${1:x}, ${2:y}, ${3:z}, '${4:b-}');",
      "xlabel('${5:X}');",
      "ylabel('${6:Y}');",
      "zlabel('${7:Z}');",
      "title('${8:Linea 3D}');",
      "grid on;",
      "view(${9:45}, ${10:30});",
      "$0"
    ],
    "description": "Linea en 3 dimensiones con angulo de vista"
  },
  "Octave Quiver 2D": {
    "prefix": "quiver",
    "body": [
      "[${1:X}, ${2:Y}] = meshgrid(${3:linspace(-2,2,15)}, ${4:linspace(-2,2,15)});",
      "${5:U} = ${6:-Y};",
      "${7:V} = ${8:X};",
      "figure;",
      "quiver(${1:X}, ${2:Y}, ${5:U}, ${7:V});",
      "xlabel('${9:X}');",
      "ylabel('${10:Y}');",
      "title('${11:Campo de vectores}');",
      "axis equal;",
      "$0"
    ],
    "description": "Campo de vectores 2D — flechas en grilla"
  },
  "Octave Roots": {
    "prefix": "roots",
    "body": [
      "${1:r} = roots([${2:1, 0, -1}]);",
      "$0"
    ],
    "description": "Raices de polinomio — coeficientes de mayor a menor grado"
  },
  "Octave Polyval": {
    "prefix": "polyval",
    "body": [
      "${1:y} = polyval([${2:coeficientes}], ${3:x});",
      "$0"
    ],
    "description": "Evaluar polinomio en puntos x — coefs de mayor a menor"
  },
  "Octave Polyfit": {
    "prefix": "polyfit",
    "body": [
      "${1:p} = polyfit(${2:x}, ${3:y}, ${4:grado});",
      "${5:y_fit} = polyval(${1:p}, ${2:x});",
      "$0"
    ],
    "description": "Ajuste polinomial de grado n — devuelve coeficientes"
  },
  "Octave Linear System Solve": {
    "prefix": "solve",
    "body": [
      "${1:x} = ${2:A} \\ ${3:b};",
      "$0"
    ],
    "description": "Resuelve sistema lineal Ax=b con backslash (eficiente, no usa inv)"
  },
  "Octave Matrix Inverse": {
    "prefix": "inv",
    "body": [
      "${1:Ainv} = inv(${2:A});",
      "$0"
    ],
    "description": "Inversa de matriz cuadrada — usar A\\b para sistemas lineales"
  },
  "Octave Determinant": {
    "prefix": "det",
    "body": [
      "${1:d} = det(${2:A});",
      "$0"
    ],
    "description": "Determinante de matriz cuadrada"
  },
  "Octave Eigenvalues": {
    "prefix": "eig",
    "body": [
      "[${1:V}, ${2:D}] = eig(${3:A});",
      "% D: matriz diagonal con valores propios",
      "% V: columnas son vectores propios",
      "$0"
    ],
    "description": "Valores y vectores propios — D diagonal, V columnas"
  },
  "Octave SVD": {
    "prefix": "svd",
    "body": [
      "[${1:U}, ${2:S}, ${3:V}] = svd(${4:A});",
      "% A = U * S * V'",
      "$0"
    ],
    "description": "Descomposicion en valores singulares — A = U*S*V'"
  },
  "Octave Interp1": {
    "prefix": "interp1",
    "body": [
      "${1:yi} = interp1(${2:x}, ${3:y}, ${4:xi}, '${5:linear}');",
      "$0"
    ],
    "description": "Interpolacion 1D — metodos: linear, cubic, spline, nearest"
  },
  "Octave Interp2": {
    "prefix": "interp2",
    "body": [
